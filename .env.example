# Copy to .env and fill in values.

# Database (SQLite for local dev — swap to PostgreSQL on Railway)
DATABASE_URL=sqlite+aiosqlite:///./launchchit.db
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/launchchit

# JWT
JWT_SECRET_KEY=change-me-to-a-long-random-string
# Set true in local dev to use POST /api/v1/auth/dev-token (JWT without SMS/email OTP). Never enable in production.
# DEV_SIMPLE_JWT=true

# Mailtrap Sandbox SMTP (get credentials from mailtrap.io → Email Testing → SMTP)
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USERNAME=your_mailtrap_username
SMTP_PASSWORD=your_mailtrap_password
SMTP_FROM=noreply@launchchit.com

# Integify SMS (use SMS_API_KEY, or leave it empty and use SMS_EMAIL + SMS_PASSWORD to log in)
SMS_API_KEY=your_integify_api_key
SMS_EMAIL=your_integify_dashboard_email
SMS_PASSWORD=your_integify_dashboard_password
SMS_SENDER_ID=LaunchChit
